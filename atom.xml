n class=&quot;line&quot;&gt;32&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&quot;code&quot;&gt;&lt;pre&gt;&lt;span class=&quot;line&quot;&gt;graph LR&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;subgraph &amp;quot;思&amp;quot;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	shaoyang[少阳]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	xun[巽]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	kan[坎]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	shaoyang --&amp;gt; xun &amp;amp; kan&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;end&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;subgraph &amp;quot;神&amp;quot;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	taiyang[太阳]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	dui[兑]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	qian[乾]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	taiyang --&amp;gt; dui &amp;amp; qian&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;end&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;subgraph &amp;quot;谋&amp;quot;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	shaoyin[少阴]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	zhen[震]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	li[离]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	shaoyin --&amp;gt; zhen &amp;amp; li&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;end&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;subgraph &amp;quot;明&amp;quot;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	taiyin[太阴]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	gen[艮]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	kun[坤]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	taiyin --&amp;gt; gen &amp;amp; kun&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;end&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	yang[阳]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	yin[阴]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	yang --&amp;gt; shaoyang &amp;amp; taiyang&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	yin --&amp;gt; shaoyin &amp;amp; taiyin&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	wu[吾]&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;line&quot;&gt;	wu --&amp;gt; yang &amp;amp; yin&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;</summary>
    
    
    
    
